# Copie para .env e preencha. O .env é ignorado pelo git (nunca versionar segredos).
# No esqueleto, tudo tem default em application.yml — você só precisa do .env
# quando for conectar Bling de verdade ou cifrar credenciais.

# Banco (default já aponta para o compose)
DATABASE_URL=jdbc:postgresql://localhost:5432/conciliador
DATABASE_USER=conciliador
DATABASE_PASSWORD=conciliador

# Ingestão automática (defaults: 04:00, janela de 7 dias, 3 tentativas)
INGEST_CRON=0 0 4 * * *
INGEST_LOOKBACK_DAYS=7
INGEST_MAX_ATTEMPTS=3
INGEST_RETRY_DELAY=PT2S

# App OAuth do Bling (global). client-id/secret vêm do app criado no Bling.
# A redirect-uri DEVE ser idêntica à cadastrada no app (inclui o context-path /page).
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_REDIRECT_URI=http://localhost:8080/page/integracoes/bling/retorno
# Opcionais (defaults oficiais do Bling v3):
# BLING_AUTHORIZE_URL=https://www.bling.com.br/Api/v3/oauth/authorize
# BLING_TOKEN_URL=https://www.bling.com.br/Api/v3/oauth/token
# BLING_TOKEN_SKEW=PT2M

# Chave para cifrar credenciais do Meu Pluggy/Cora (por empresa) e refresh token Bling
CRIPTO_KEY=

# Integração direta com o Cora (OAuth client-credentials + mTLS). Defaults em
# application.yml já apontam para a API do Cora; só sobrescreva se necessário.
CORA_BASE_URL=
CORA_TOKEN_PATH=
CORA_EXTRATO_PATH=
CORA_SALDO_PATH=


PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_API=

# Webhook Pluggy: segredo enviado como header em cada chamada (a Pluggy não
# assina o corpo, só ecoa headers customizados definidos no registro) e a URL
# pública do Conector usada para montar a URL do webhook. Em produção
# APP_PUBLIC_URL precisa ser não-localhost, senão a Pluggy rejeita o registro.
PLUGGY_WEBHOOK_SECRET=
APP_PUBLIC_URL=http://localhost:8080/page